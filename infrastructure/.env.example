# ════════════════════════════════════════════════════════════════════════════
# SmartEduLearn — Environment Variables
# Copy this file to infrastructure/.env and fill in your real values.
# NEVER commit the actual .env file to git.
# ════════════════════════════════════════════════════════════════════════════

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ─── SERVICE PORTS ───────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
COURSE_SERVICE_PORT=3003
AI_SERVICE_PORT=3004
QUIZ_SERVICE_PORT=3005
GAMIFICATION_SERVICE_PORT=3006
TUTOR_SERVICE_PORT=3007
PAYMENT_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3010
ADMIN_SERVICE_PORT=3011

# ─── SERVICE URLS ────────────────────────────────────────────────────────────
# When running with Docker: use container names (e.g. http://sel_auth:3001)
# When running locally without Docker: use localhost
AUTH_SERVICE_URL=http://sel_auth:3001
COURSE_SERVICE_URL=http://sel_course:3003
AI_SERVICE_URL=http://sel_ai:3004
QUIZ_SERVICE_URL=http://sel_quiz:3005
GAMIFICATION_SERVICE_URL=http://sel_gamification:3006
TUTOR_SERVICE_URL=http://sel_tutor:3007
PAYMENT_SERVICE_URL=http://sel_payment:3008
NOTIFICATION_SERVICE_URL=http://sel_notification:3010
ADMIN_SERVICE_URL=http://sel_admin:3011

# ─── DATABASES ───────────────────────────────────────────────────────────────
# Docker: use container names. Local: use localhost
DATABASE_URL=postgresql://sel_user:sel_pass@sel_postgres:5432/smartedulear
MONGODB_URL=mongodb://sel_mongodb:27017
REDIS_URL=redis://sel_redis:6379

# For local dev without Docker, use:
# DATABASE_URL=postgresql://sel_user:sel_pass@localhost:5432/smartedulear
# MONGODB_URL=mongodb://localhost:27017
# REDIS_URL=redis://localhost:6379

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── GEMINI (Google AI) ───────────────────────────────────────────────────────
# Get free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# Options: gemini-1.5-flash (fast/free), gemini-1.5-pro (smarter), gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# ─── PINECONE (optional — for AI chat RAG) ────────────────────────────────────
# Get from: https://www.pinecone.io — free tier available
# If not set, AI chat still works, just without course-specific context
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=smartedulear-courses

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: enable 2FA → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=noreply@smartedulear.com

# ─── AWS S3 (optional — for file uploads) ────────────────────────────────────
# Can use Cloudinary instead — just swap the upload logic
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smartedulear-uploads

# ─── POSTGRES (used by docker-compose) ───────────────────────────────────────
POSTGRES_USER=sel_user
POSTGRES_PASSWORD=sel_pass
