{
  "name": "smartedulear-server",
  "version": "1.0.0",
  "description": "SmartEduLearn - Unified Backend Server",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:migrate": "node scripts/migrate.js && node src/index.js",
    "db:migrate": "node scripts/migrate.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:verbose": "jest --runInBand --forceExit --detectOpenHandles --verbose",
    "test:coverage": "jest --runInBand --forceExit --detectOpenHandles --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@pinecone-database/pinecone": "^2.2.2",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cashfree-pg": "^4.0.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.5",
    "redis": "^4.6.14",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2"
  }
}
