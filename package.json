{
  "name": "smartedulear",
  "version": "2.0.0",
  "private": true,
  "description": "SmartEduLearn — AI-powered personalized learning platform",
  "scripts": {
    "dev:server":        "npm run dev --prefix server",
    "dev:frontend":      "npm run dev --prefix frontend",
    "install:all":       "npm install --prefix server --legacy-peer-deps && npm install --prefix frontend",
    "db:migrate":        "npm run db:migrate --prefix server",
    "docker:up":         "docker compose up -d",
    "docker:down":       "docker compose down",
    "docker:build":      "docker compose build",
    "docker:rebuild":    "docker compose build --no-cache",
    "docker:logs":       "docker compose logs -f",
    "docker:logs:server":"docker compose logs -f server",
    "docker:restart":    "docker compose restart server",
    "docker:clean":      "docker compose down -v --remove-orphans",
    "test":              "npm test --prefix server"
  }
}
