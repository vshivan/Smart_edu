# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Environment / Secrets ───────────────────────────────────────────────────
# NEVER commit real secrets
.env
.env.local
.env.*.local
.env.production
server/.env
frontend/.env.local

# frontend/.env.production is tracked — it only contains VITE_API_URL (no secrets)
!frontend/.env.production

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
.vite/
frontend/dist/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
server/logs/

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── Docker local volumes ─────────────────────────────────────────────────────
postgres_data/
mongo_data/
redis_data/

# ─── SSL / Uploads ────────────────────────────────────────────────────────────
uploads/
nginx/ssl/
*.pem
*.key
*.cert
