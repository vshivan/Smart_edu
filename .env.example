# ════════════════════════════════════════════════════════════════════════════
# SmartEduLearn — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# ════════════════════════════════════════════════════════════════════════════

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── DATABASES ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sel_user:sel_pass@localhost:5432/smartedulear
MONGODB_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379
POSTGRES_USER=sel_user
POSTGRES_PASSWORD=sel_pass

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ─── GOOGLE OAUTH (optional) ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── GEMINI AI ────────────────────────────────────────────────────────────────
# ✅ REQUIRED — Free key: https://aistudio.google.com/app/apikey
# Models: gemini-1.5-flash (fast/free) | gemini-1.5-pro (smarter) | gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─── PINECONE (optional) ──────────────────────────────────────────────────────
# AI chat with course-specific context. App works fine without this.
# Free tier: https://www.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=smartedulear-courses

# ─── CASHFREE PAYMENTS ────────────────────────────────────────────────────────
# Free Indian payment gateway (UPI, cards, netbanking)
# Signup: https://merchant.cashfree.com (free, instant)
# Dashboard → Developers → API Keys → copy Test Mode keys
# Test App ID starts with TEST... (no real money in test mode)
# If not set → app runs in demo mode (payments show mock success)
CASHFREE_APP_ID=your-cashfree-test-app-id
CASHFREE_SECRET_KEY=your-cashfree-test-secret-key
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret

# ─── EMAIL — Gmail + Nodemailer (FREE) ────────────────────────────────────────
# Works with any Gmail account — no signup, no cost
# Setup (2 minutes):
#   Step 1: myaccount.google.com → Security → 2-Step Verification → Turn ON
#   Step 2: myaccount.google.com → Security → App Passwords
#   Step 3: Select app "Mail", device "Other" → Generate
#   Step 4: Copy the 16-char password (format: xxxx xxxx xxxx xxxx)
# If not set → emails are logged to console only (perfectly fine for dev)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── AWS S3 (optional — file/image uploads) ───────────────────────────────────
# Skip entirely — app works without it
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=smartedulear-uploads
